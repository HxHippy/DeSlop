{
  "manifest_version": 3,
  "name": "__MSG_extensionName__",
  "version": "3.0.0",
  "description": "__MSG_extensionDescription__",
  "default_locale": "en",
  "author": "Kief Studio",
  "homepage_url": "https://kief.studio",
  "permissions": [
    "storage",
    "activeTab",
    "declarativeNetRequest",
    "sidePanel",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["patterns/registry.js", "patterns/en.js", "content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["*://*.linkedin.com/*"],
      "js": ["linkedin-fixer.js"],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "popup.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "linkedin_ad_blocker",
        "enabled": false,
        "path": "rules.json"
      }
    ]
  },
  "web_accessible_resources": [
    {
      "resources": [
        "patterns/*.js",
        "scoring-engine.js",
        "languages.js",
        "i18n-helper.js",
        "_locales/*/messages.json"
      ],
      "matches": ["<all_urls>"]
    }
  ]
}
